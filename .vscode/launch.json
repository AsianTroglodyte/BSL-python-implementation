    "version": "0.2.0",
    "configurations": [
        {
            "name": "BSL: Run package entrypoint",
            "type": "debugpy",
            "request": "launch",
            "module": "bsl",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal"
        },
